# Copy to .env and fill in. Vite only exposes VITE_* prefixed vars to the bundle.
# NOTE: any value here is inlined into the client JS at build time and is
# therefore extractable by end users. For private deployments that's fine.
# For public deployments, prefer runtime provisioning via:
#   - URL params:  ?key=YOUR_KEY&region=uksouth
#   - config file: { "settings": { "azureKey": "...", "azureRegion": "..." } }
#   - the in-app Settings panel (persists to localStorage)

VITE_AZURE_KEY=
VITE_AZURE_REGION=
